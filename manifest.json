{
  "manifest_version": 3,
  "name": "Heren V2",
  "version": "2.0",
  "description": "Automatically saves copied texts and allows viewing them with a shortcut",
  "permissions": [
    "storage",
    "alarms",
    "clipboardRead",
    "clipboardWrite",
    "activeTab",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["foreground.js"]
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+H"
      },
      "description": "Open Heren Keep popup"
    }
  }
}
